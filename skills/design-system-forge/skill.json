    "dissect": "lib/dissect.mjs",
    "extract-states": "lib/extract-states.mjs",
    "extract-dark-mode": "lib/extract-dark-mode.mjs",
    "scrape-references": "lib/scrape-references.mjs",
    "consolidate-tokens": "lib/consolidate-tokens.mjs",
    "generate-tailwind": "lib/generate-tailwind.mjs",
    "visual-diff": "lib/visual-diff.mjs"
  },
  "pipeline": [
    "/design-system-forge — Extract DNA (this skill)",
